{
  "name": "ngx-charts",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/szymon-koschel/ngx-charts.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build @koschel/ngx-charts",
    "build:lib:prod": "ng build @koschel/ngx-charts --configuration production",
    "build:demo": "npm run build:lib:prod && cross-env NODE_ENV=production ng build --configuration production --base-href=\"/ngx-charts/\"",
    "copy-files": "cp README.md dist/swimlane/ngx-charts/README.md && cp LICENSE dist/swimlane/ngx-charts/LICENSE  && cp docs/changelog.md dist/swimlane/ngx-charts/CHANGELOG.md",
    "ci": "run-s lint prettier:ci test:ci",
    "test": "run-s lint prettier:ci test:unit",
    "test:unit": "ng test @koschel/ngx-charts --watch=false",
    "test:watch": "ng test @koschel/ngx-charts",
    "test:ci": "ng test @koschel/ngx-charts --watch=false --progress=false --browsers=ChromeHeadlessCI",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "predeploy": "npm run build:demo",
    "deploy": "angular-cli-ghpages --dir ./dist/ngx-charts --no-silent",
    "package": "run-s build:lib:prod copy-files",
    "prepublish:lib": "npm run package",
    "publish:lib": "npm publish --access public ./dist/swimlane/ngx-charts",
    "publish:lib:beta": "npm publish ./dist/swimlane/ngx-charts --tag beta",
    "prepack": "npm run package",
    "pack": "npm pack ./dist/swimlane/ngx-charts",
    "prettier": "prettier --write \"{src,projects}/**/*.{js,ts,html,scss,css,md,json}\"",
    "prettier:ci": "prettier --check \"{src,projects}/**/*.{js,ts,html,scss,css,md,json}\"",
    "fix": "run-s lint fix:*",
    "fix:prettier": "prettier --write \"{src,projects}/**/*.{js,ts,html,scss,css,md,json}\"",
    "fix:lint": "ng lint --fix"
  },
  "dependencies": {
    "@angular/animations": "~21.1.0",
    "@angular/cdk": "~21.1.0",
    "@angular/common": "~21.1.0",
    "@angular/compiler": "~21.1.0",
    "@angular/core": "~21.1.0",
    "@angular/flex-layout": "15.0.0-beta.42",
    "@angular/forms": "~21.1.0",
    "@angular/platform-browser": "~21.1.0",
    "@angular/platform-browser-dynamic": "~21.1.0",
    "@angular/router": "~21.1.0",
    "@swimlane/ngx-ui": "50.0.3",
    "ajv": "8.17.1",
    "codemirror": "^5.65.0",
    "d3-array": "^3.2.4",
    "d3-brush": "^3.0.0",
    "d3-color": "^3.1.0",
    "d3-ease": "^3.0.1",
    "d3-format": "^3.1.2",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1",
    "emoji-flags": "^1.3.0",
    "moment-timezone": "^0.5.40",
    "ng-in-viewport": "13.0.1",
    "ngx-moment": "^5.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2101.0",
    "@angular-devkit/build-angular": "~21.1.0",
    "@angular-devkit/build-ng-packagr": "0.1002.0",
    "@angular-eslint/builder": "~21.1.0",
    "@angular-eslint/eslint-plugin": "^21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.1.0",
    "@angular-eslint/schematics": "~21.1.0",
    "@angular-eslint/template-parser": "^21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@swimlane/eslint-config": "^2.0.0",
    "@swimlane/prettier-config-swimlane": "^3.0.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-transition": "^3.0.9",
    "@types/jasmine": "^4.0.0",
    "@types/jasminewd2": "~2.0.13",
    "@types/json-schema": "^7.0.15",
    "@types/karma-firefox-launcher": "^2",
    "@types/node": "^18.11.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@typescript-eslint/types": "^8.53.1",
    "@typescript-eslint/utils": "^8.53.1",
    "angular-cli-ghpages": "^2.0.3",
    "cross-env": "^7.0.2",
    "electron": "^38.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-security": "^1.5.0",
    "jasmine-core": "~4.2.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-electron-launcher": "^0.3.0",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "ng-packagr": "^21.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.0",
    "protractor": "~7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "webpack": "5"
  },
  "volta": {
    "node": "22.16.0",
    "yarn": "4.9.2"
  },
  "packageManager": "yarn@4.9.2"
}
